# ===========================================
# Afri Cleans - Frontend Environment Template
# Copy to frontend/.env
# ===========================================

# Backend API base URL (dev)
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# UK VAT defaults for frontend fallback.
# (Live values are fetched from /api/vat-config/)
VITE_DEFAULT_VAT_RATE=0.20
VITE_APPLY_VAT_BY_DEFAULT=true
