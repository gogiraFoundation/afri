# ===========================================
# Afri Cleans - Website Environment Template
# Copy this file to `.env` and fill values.
# ===========================================

# ---- Core / Django backend ----
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUST_X_FORWARDED_PROTO=false
LOG_LEVEL=INFO

# Optional hardening in production
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=false

# ---- Database ----
# Local SQLite is used when DATABASE_URL is not set.
# Example Postgres URL:
# DATABASE_URL=postgres://africleans:strong-password@db:5432/africleans
DATABASE_URL=

# ---- Email ----
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com
ADMIN_EMAIL=admin@example.com
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ---- UK VAT / Tax ----
DEFAULT_VAT_RATE=0.20
APPLY_VAT_BY_DEFAULT=True

# ---- Frontend (Vite) ----
# If frontend runs standalone, point to your backend API.
VITE_API_BASE_URL=http://127.0.0.1:8000/api
VITE_DEFAULT_VAT_RATE=0.20
VITE_APPLY_VAT_BY_DEFAULT=true

# ---- Docker Compose helpers ----
POSTGRES_PASSWORD=change-me-in-production
FRONTEND_PORT=80
