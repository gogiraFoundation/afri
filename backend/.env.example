# ===========================================
# Afri Cleans - Backend Environment Template
# Copy to backend/.env and fill real values.
# ===========================================

ENVIRONMENT=development
DEBUG=True
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend origins that can call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Reverse proxy / TLS
TRUST_X_FORWARDED_PROTO=false
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=false

# Logging
LOG_LEVEL=INFO

# Database
# Leave empty for local SQLite.
# Example: postgres://africleans:strong-password@db:5432/africleans
DATABASE_URL=

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com
ADMIN_EMAIL=admin@example.com
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# UK VAT / Tax
DEFAULT_VAT_RATE=0.20
APPLY_VAT_BY_DEFAULT=True

# Docker compose helper
POSTGRES_PASSWORD=change-me-in-production
