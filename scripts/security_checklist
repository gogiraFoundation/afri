#!/usr/bin/env bash
# Afri — pre-deployment security audit (local gate before deploy).
# Mirrors .github/workflows/security-checks.yml plus repo hygiene checks.
#
# Usage:
#   ./scripts/security_checklist              # full audit
#   ./scripts/security_checklist --quick      # skip frontend production build
#   ./scripts/security_checklist --skip-gitleaks
#   ./scripts/security_checklist --verbose
#
# Exit code: 0 if all required checks pass, 1 otherwise.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
BACKEND="$ROOT/backend"
FRONTEND="$ROOT/frontend"

QUICK=0
SKIP_FRONTEND=0
SKIP_BACKEND=0
SKIP_GITLEAKS=0
VERBOSE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --quick) QUICK=1; shift ;;
    --skip-frontend) SKIP_FRONTEND=1; shift ;;
    --skip-backend) SKIP_BACKEND=1; shift ;;
    --skip-gitleaks) SKIP_GITLEAKS=1; shift ;;
    -v|--verbose) VERBOSE=1; shift ;;
    -h|--help)
      grep '^#' "$0" | head -n 12 | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 2
      ;;
  esac
done

PASS=0
FAIL=0
SKIP=0
WARN=0

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log_section() { echo -e "\n${CYAN}=== $1 ===${NC}"; }
log_ok()    { echo -e "${GREEN}PASS${NC}  $1"; PASS=$((PASS + 1)); }
log_fail()  { echo -e "${RED}FAIL${NC}  $1"; FAIL=$((FAIL + 1)); }
log_skip()  { echo -e "${YELLOW}SKIP${NC}  $1"; SKIP=$((SKIP + 1)); }
log_warn()  { echo -e "${YELLOW}WARN${NC}  $1"; WARN=$((WARN + 1)); }

run_logged() {
  local title=$1
  shift
  if [[ "$VERBOSE" -eq 1 ]]; then
    echo "+ $*" >&2
    if "$@"; then
      log_ok "$title"
      return 0
    fi
    log_fail "$title"
    return 1
  fi
  if "$@" >/dev/null 2>&1; then
    log_ok "$title"
    return 0
  fi
  log_fail "$title"
  return 1
}

resolve_python() {
  if [[ -x "$BACKEND/.venv/bin/python" ]]; then
    echo "$BACKEND/.venv/bin/python"
  elif command -v python3 &>/dev/null; then
    command -v python3
  else
    echo ""
  fi
}

ensure_python_tool() {
  local py=$1
  local import_name=$2
  local pip_name=${3:-$import_name}
  if ! "$py" -c "import ${import_name}" 2>/dev/null; then
    echo "Installing ${pip_name}..." >&2
    "$py" -m pip install -q "$pip_name"
  fi
}

export DJANGO_SETTINGS_MODULE=afri_cleans.settings
export ENVIRONMENT=production
export DEBUG=False
export SECRET_KEY="${SECRET_KEY:-ci-security-check-secret-key-must-be-at-least-fifty-chars-long}"
export ALLOWED_HOSTS="${ALLOWED_HOSTS:-example.com}"
export CSRF_TRUSTED_ORIGINS="${CSRF_TRUSTED_ORIGINS:-https://example.com}"
export CORS_ALLOWED_ORIGINS="${CORS_ALLOWED_ORIGINS:-https://example.com}"
export CONTACT_FORM_CAPTCHA_SECRET="${CONTACT_FORM_CAPTCHA_SECRET:-ci-placeholder-not-used-in-tests}"

# --- Repository hygiene ---
log_section "Repository hygiene"

if git -C "$ROOT" rev-parse --is-inside-work-tree &>/dev/null; then
  tracked_env=0
  for f in .env backend/.env frontend/.env; do
    if git -C "$ROOT" ls-files --error-unmatch "$f" &>/dev/null; then
      tracked_env=1
      [[ "$VERBOSE" -eq 1 ]] && echo "  tracked: $f" >&2
    fi
  done
  if [[ "$tracked_env" -eq 1 ]]; then
    log_fail "No .env files should be tracked by git"
  else
    log_ok "No tracked .env files"
  fi

  secret_hits=0
  if command -v rg &>/dev/null; then
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      secret_hits=$((secret_hits + 1))
      [[ "$VERBOSE" -eq 1 ]] && echo "  suspicious: $f" >&2
    done < <(
      rg -l --glob '!.git' --glob '!**/node_modules/**' --glob '!package-lock.json' \
        -e 'BEGIN (RSA |OPENSSH )?PRIVATE KEY' \
        -e 'aws_secret_access_key\s*=' \
        -e 'sk_live_[0-9a-zA-Z]{10,}' \
        "$ROOT" 2>/dev/null || true
    )
  fi
  if [[ "$secret_hits" -gt 0 ]]; then
    log_fail "Possible secrets in repo ($secret_hits hit(s); use --verbose)"
  else
    log_ok "No obvious secret patterns (rg scan)"
  fi
else
  log_skip "Git hygiene checks (not a git repo)"
fi

if [[ -f "$ROOT/SECURITY.md" ]]; then
  if grep -q 'Tell them where to go' "$ROOT/SECURITY.md" 2>/dev/null; then
    log_fail "SECURITY.md still looks like the GitHub template — add a real disclosure contact"
  else
    log_ok "SECURITY.md present (not default template)"
  fi
else
  log_fail "SECURITY.md missing"
fi

if [[ -f "$BACKEND/.dockerignore" ]] && grep -qE '^\.env$' "$BACKEND/.dockerignore"; then
  log_ok "backend/.dockerignore excludes .env"
else
  log_fail "backend/.dockerignore should exclude .env"
fi

if [[ -f "$FRONTEND/nginx.conf" ]]; then
  for hdr in X-Content-Type-Options X-Frame-Options Strict-Transport-Security Content-Security-Policy; do
    if grep -q "$hdr" "$FRONTEND/nginx.conf"; then
      log_ok "nginx.conf includes $hdr"
    else
      log_fail "nginx.conf missing header: $hdr"
    fi
  done
else
  log_skip "nginx.conf security headers (file not found)"
fi

# --- gitleaks ---
if [[ "$SKIP_GITLEAKS" -eq 0 ]]; then
  log_section "Secret scanning (gitleaks)"
  if command -v gitleaks &>/dev/null; then
    gitleaks_args=(detect --source "$ROOT" --no-banner --redact)
    [[ "$VERBOSE" -eq 1 ]] && gitleaks_args+=(--verbose)
    if gitleaks "${gitleaks_args[@]}"; then
      log_ok "gitleaks detect"
    else
      log_fail "gitleaks detect — findings reported"
    fi
  else
    log_skip "gitleaks not installed (brew install gitleaks)"
  fi
fi

# --- Backend ---
if [[ "$SKIP_BACKEND" -eq 0 ]]; then
  log_section "Backend (Django / Python)"
  PY="$(resolve_python)"
  if [[ -z "$PY" ]]; then
    log_fail "python3 not found — create: python3 -m venv backend/.venv"
  elif [[ ! -f "$BACKEND/requirements.txt" ]]; then
    log_fail "backend/requirements.txt missing"
  else
    if [[ ! -x "$BACKEND/.venv/bin/python" ]]; then
      log_warn "Using system python3; recommended: backend/.venv"
    fi

    "$PY" -m pip install -q -r "$BACKEND/requirements.txt" 2>/dev/null || true
    ensure_python_tool "$PY" bandit bandit
    ensure_python_tool "$PY" pip_audit pip-audit

    log_section "Django deploy checks"
    if (cd "$BACKEND" && "$PY" manage.py check --deploy); then
      log_ok "manage.py check --deploy (ENVIRONMENT=production)"
    else
      log_fail "manage.py check --deploy"
    fi

    # Production must refuse boot without captcha secret (unless explicit opt-out).
    if (cd "$BACKEND" && \
      CONTACT_FORM_CAPTCHA_SECRET= \
      ALLOW_PUBLIC_FORMS_WITHOUT_CAPTCHA=false \
      "$PY" -c "
import os, sys
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'afri_cleans.settings')
os.environ['ENVIRONMENT'] = 'production'
os.environ['DEBUG'] = 'False'
os.environ['SECRET_KEY'] = 'audit-test-secret'
os.environ['ALLOWED_HOSTS'] = 'example.com'
os.environ['CONTACT_FORM_CAPTCHA_SECRET'] = ''
os.environ['ALLOW_PUBLIC_FORMS_WITHOUT_CAPTCHA'] = 'false'
try:
    from django.core.exceptions import ImproperlyConfigured
    import django
    django.setup()
except ImproperlyConfigured:
    sys.exit(0)
except Exception:
    sys.exit(0)
sys.exit(1)
"); then
      log_ok "Production captcha boot guard (no secret + no opt-out)"
    else
      log_fail "Production should refuse boot without CONTACT_FORM_CAPTCHA_SECRET"
    fi

    log_section "Bandit (SAST)"
    if (cd "$BACKEND" && "$PY" -m bandit -r . -c bandit.yaml -q); then
      log_ok "bandit -r backend"
    else
      log_fail "bandit -r backend"
    fi

    log_section "pip-audit"
    if [[ "$VERBOSE" -eq 1 ]]; then
      pip_audit_out=$(cd "$BACKEND" && pip-audit -r requirements.txt 2>&1) || true
      echo "$pip_audit_out"
      if echo "$pip_audit_out" | grep -q 'No known vulnerabilities found'; then
        log_ok "pip-audit"
      else
        log_fail "pip-audit — vulnerabilities found"
      fi
    else
      if (cd "$BACKEND" && pip-audit -r requirements.txt 2>&1 | grep -q 'No known vulnerabilities found'); then
        log_ok "pip-audit"
      else
        log_fail "pip-audit — vulnerabilities found"
      fi
    fi
  fi
fi

# --- Frontend (delegated) ---
if [[ "$SKIP_FRONTEND" -eq 0 ]]; then
  fc_args=()
  [[ "$QUICK" -eq 1 ]] && fc_args+=(--quick)
  [[ "$VERBOSE" -eq 1 ]] && fc_args+=(--verbose)
  if ! bash "$SCRIPT_DIR/security_checklist_frontend" "${fc_args[@]}"; then
    log_fail "Frontend security checklist failed (see output above)"
    FAIL=$((FAIL + 1))
  fi
fi

log_section "Manual checks (verify before deploy)"
echo "  [ ] CORS_ALLOWED_ORIGINS / CSRF_TRUSTED_ORIGINS match live frontend URL"
echo "  [ ] CONTACT_FORM_CAPTCHA_SECRET on Cloud Run (no ALLOW_PUBLIC_FORMS_WITHOUT_CAPTCHA)"
echo "  [ ] DATABASE_URL → managed Postgres (not ephemeral SQLite on Cloud Run)"
echo "  [ ] Edge/WAF rate limits on POST /api/bookings/ and /api/contact-requests/"
echo "  [ ] /admin/ restricted (IP/VPN/IAP) and MFA on operator accounts"
echo "  [ ] Cloudflare security headers on Pages"
echo "  [ ] Logs omit full booking/contact request bodies"

log_section "Summary"
echo "  Passed:   $PASS"
echo "  Failed:   $FAIL"
echo "  Skipped:  $SKIP"
echo "  Warnings: $WARN"

if [[ "$FAIL" -gt 0 ]]; then
  echo -e "\n${RED}Security audit FAILED — fix failures before deploying.${NC}"
  exit 1
fi

if [[ "$WARN" -gt 0 ]]; then
  echo -e "\n${YELLOW}Security audit passed with warnings — review before deploying.${NC}"
else
  echo -e "\n${GREEN}Security audit PASSED.${NC}"
fi
exit 0
