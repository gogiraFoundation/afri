#!/usr/bin/env bash
# Afri — frontend-only pre-deployment security audit (Vite/React SPA).
#
# Usage:
#   ./scripts/security_checklist_frontend
#   ./scripts/security_checklist_frontend --quick    # skip production build
#   ./scripts/security_checklist_frontend --verbose
#
# Exit code: 0 if all checks pass, 1 otherwise.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
FRONTEND="$ROOT/frontend"
SRC="$FRONTEND/src"

QUICK=0
VERBOSE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --quick) QUICK=1; shift ;;
    -v|--verbose) VERBOSE=1; shift ;;
    -h|--help)
      grep '^#' "$0" | head -n 10 | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 2
      ;;
  esac
done

PASS=0
FAIL=0
SKIP=0
WARN=0

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log_section() { echo -e "\n${CYAN}=== $1 ===${NC}"; }
log_ok()    { echo -e "${GREEN}PASS${NC}  $1"; PASS=$((PASS + 1)); }
log_fail()  { echo -e "${RED}FAIL${NC}  $1"; FAIL=$((FAIL + 1)); }
log_skip()  { echo -e "${YELLOW}SKIP${NC}  $1"; SKIP=$((SKIP + 1)); }
log_warn()  { echo -e "${YELLOW}WARN${NC}  $1"; WARN=$((WARN + 1)); }

# --- Repository & config ---
log_section "Repository & configuration"

if git -C "$ROOT" rev-parse --is-inside-work-tree &>/dev/null; then
  if git -C "$ROOT" ls-files --error-unmatch frontend/.env &>/dev/null; then
    log_fail "frontend/.env must not be tracked by git"
  else
    log_ok "frontend/.env not tracked"
  fi
else
  log_skip "Git tracked-env check"
fi

if [[ -f "$FRONTEND/.env.example" ]]; then
  log_ok "frontend/.env.example present"
else
  log_fail "frontend/.env.example missing"
fi

if [[ -f "$FRONTEND/public/_redirects" ]] && grep -q 'index.html' "$FRONTEND/public/_redirects"; then
  log_ok "SPA _redirects for Cloudflare Pages"
else
  log_fail "public/_redirects missing or incomplete (SPA fallback)"
fi

if [[ -f "$FRONTEND/nginx.conf" ]]; then
  for hdr in X-Content-Type-Options X-Frame-Options Strict-Transport-Security Content-Security-Policy Permissions-Policy; do
    if grep -q "$hdr" "$FRONTEND/nginx.conf"; then
      log_ok "nginx.conf: $hdr"
    else
      log_fail "nginx.conf missing: $hdr"
    fi
  done
  if grep -q 'server_tokens off' "$FRONTEND/nginx.conf"; then
    log_ok "nginx.conf: server_tokens off"
  else
    log_warn "nginx.conf: consider server_tokens off"
  fi
else
  log_skip "nginx.conf (Docker frontend proxy not used)"
fi

# --- Source hygiene ---
log_section "Source code hygiene"

if [[ ! -d "$SRC" ]]; then
  log_fail "frontend/src not found"
else
  if command -v rg &>/dev/null; then
    unsafe_hits=0
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      unsafe_hits=$((unsafe_hits + 1))
      [[ "$VERBOSE" -eq 1 ]] && echo "  $line" >&2
    done < <(
      rg -n --glob '*.ts' --glob '*.tsx' \
        -e '\beval\s*\(' \
        -e 'new\s+Function\s*\(' \
        -e 'document\.write\s*\(' \
        "$SRC" 2>/dev/null || true
    )
    if [[ "$unsafe_hits" -gt 0 ]]; then
      log_fail "Unsafe JS patterns in src (eval / Function / document.write)"
    else
      log_ok "No eval / Function / document.write in src"
    fi

    secret_vite=0
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      secret_vite=$((secret_vite + 1))
      [[ "$VERBOSE" -eq 1 ]] && echo "  $line" >&2
    done < <(
      rg -n 'VITE_[A-Z0-9_]*(SECRET|PASSWORD|PRIVATE|TOKEN|API_KEY)' "$FRONTEND" \
        --glob '!node_modules' --glob '!dist' 2>/dev/null || true
    )
    if [[ "$secret_vite" -gt 0 ]]; then
      log_fail "VITE_* env names suggest secrets (they are embedded in the client bundle)"
    else
      log_ok "No secret-like VITE_* variable names"
    fi

    if rg -q 'rehype-raw|rehypeRaw|allowDangerousHtml' "$SRC" 2>/dev/null; then
      log_fail "Raw HTML in Markdown pipeline detected (XSS risk)"
    else
      log_ok "No raw-HTML Markdown plugins in src"
    fi

    dang_files=()
    while IFS= read -r f; do
      [[ -n "$f" ]] && dang_files+=("$f")
    done < <(rg -l 'dangerouslySetInnerHTML' "$SRC" 2>/dev/null || true)

    if [[ ${#dang_files[@]} -eq 0 ]]; then
      log_ok "No dangerouslySetInnerHTML usage"
    elif [[ ${#dang_files[@]} -eq 1 ]] && [[ "${dang_files[0]}" == *OnePagerPage.tsx ]]; then
      if grep -q 'qrcode' "$SRC/pages/OnePagerPage.tsx" 2>/dev/null; then
        log_ok "dangerouslySetInnerHTML only in OnePagerPage (QR SVG from qrcode lib)"
      else
        log_warn "dangerouslySetInnerHTML in OnePagerPage — verify HTML is trusted"
      fi
    else
      log_fail "dangerouslySetInnerHTML in unexpected files: ${dang_files[*]}"
    fi

    if rg -q 'http://localhost' "$SRC/api/client.ts" 2>/dev/null; then
      log_ok "API client has localhost fallback (ensure production sets VITE_API_BASE_URL)"
    fi
  else
    # grep fallback when ripgrep is not installed
    unsafe_hits=0
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      unsafe_hits=$((unsafe_hits + 1))
    done < <(grep -rEl '\beval\s*\(|new\s+Function\s*\(|document\.write\s*\(' "$SRC" --include='*.ts' --include='*.tsx' 2>/dev/null || true)
    if [[ "$unsafe_hits" -gt 0 ]]; then
      log_fail "Unsafe JS patterns in src (eval / Function / document.write)"
    else
      log_ok "No eval / Function / document.write in src (grep)"
    fi
    log_skip "Extended source scans need ripgrep (brew install ripgrep)"
  fi
fi

# --- Dependencies & build ---
log_section "Dependencies & build"

if ! command -v npm &>/dev/null; then
  log_fail "npm not found"
elif [[ ! -f "$FRONTEND/package-lock.json" ]]; then
  log_fail "package-lock.json missing — run npm install in frontend/"
else
  if (cd "$FRONTEND" && npm ci); then
    log_ok "npm ci"
  else
    log_fail "npm ci"
  fi

  # Ensure local CLI tools (tsc, eslint) resolve after npm ci
  export PATH="$FRONTEND/node_modules/.bin:$PATH"

  if (cd "$FRONTEND" && npm audit --audit-level=high); then
    log_ok "npm audit --audit-level=high"
  else
    log_fail "npm audit --audit-level=high"
  fi

  if (cd "$FRONTEND" && npm run lint); then
    log_ok "npm run lint (ESLint + TypeScript)"
  else
    log_fail "npm run lint"
  fi

  if [[ "$QUICK" -eq 1 ]]; then
    log_skip "npm run build (--quick)"
  elif (cd "$FRONTEND" && npm run build); then
    log_ok "npm run build"
  else
    log_fail "npm run build"
  fi
fi

# --- Production bundle ---
log_section "Production bundle"

if [[ ! -d "$FRONTEND/dist" ]]; then
  log_skip "dist/ not found (run build or drop --quick)"
else
  _dist_grep() {
    if command -v rg &>/dev/null; then
      rg -q "$1" "$FRONTEND/dist" 2>/dev/null
    else
      grep -rqE "$1" "$FRONTEND/dist" 2>/dev/null
    fi
  }

  if _dist_grep 'SECRET_KEY|CONTACT_FORM_CAPTCHA_SECRET|sk_live_|BEGIN (RSA |OPENSSH )?PRIVATE KEY'; then
    log_fail "Suspicious strings in dist/ — remove secrets from VITE_ env"
  else
    log_ok "No obvious secrets in dist/"
  fi

  if [[ -f "$FRONTEND/.env.production" ]]; then
    if _dist_grep 'localhost:8000|127\.0\.0\.1:8000'; then
      log_fail "dist/ still references local API — fix VITE_API_BASE_URL in .env.production"
    else
      log_ok "dist/ does not embed local API URL"
    fi
  elif [[ -f "$FRONTEND/.env" ]]; then
    if _dist_grep 'localhost:8000|127\.0\.0\.1:8000'; then
      log_warn "dist/ contains local API URL — set .env.production for deploy builds"
    else
      log_ok "dist/ API URL looks non-local (or booking disabled)"
    fi
  else
    if _dist_grep 'localhost:8000'; then
      log_warn "dist/ may default API to localhost — set VITE_API_BASE_URL before production deploy"
    else
      log_ok "dist/ has no obvious localhost API string"
    fi
  fi

  if [[ -f "$FRONTEND/dist/index.html" ]]; then
    if grep -qE '<script[^>]+src="https?://' "$FRONTEND/dist/index.html" 2>/dev/null; then
      log_warn "Third-party script tags in built index.html — review CSP"
    else
      log_ok "Built index.html has no extra third-party script tags"
    fi
  fi
fi

log_section "Manual checks (before Cloudflare / nginx deploy)"
echo "  [ ] Cloudflare Pages: HTTPS, HSTS, X-Content-Type-Options, CSP (see deploy_frontend_cloudflare.md)"
echo "  [ ] VITE_PUBLIC_SITE_ORIGIN set to production URL at build time"
echo "  [ ] VITE_RECAPTCHA_SITE_KEY set if booking forms call the API (site key only — never the secret)"
echo "  [ ] VITE_API_BASE_URL points to production API (or same-origin /api behind nginx)"
echo "  [ ] CSP allows google.com/recaptcha if booking + captcha enabled"
echo "  [ ] No analytics/tracking scripts without consent banner (if required)"
echo "  [ ] Deep links (/pricing, /book, /brochure) tested after deploy"

log_section "Summary"
echo "  Passed:   $PASS"
echo "  Failed:   $FAIL"
echo "  Skipped:  $SKIP"
echo "  Warnings: $WARN"

if [[ "$FAIL" -gt 0 ]]; then
  echo -e "\n${RED}Frontend security audit FAILED.${NC}"
  exit 1
fi

if [[ "$WARN" -gt 0 ]]; then
  echo -e "\n${YELLOW}Frontend security audit passed with warnings.${NC}"
else
  echo -e "\n${GREEN}Frontend security audit PASSED.${NC}"
fi
exit 0
